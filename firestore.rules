rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdminOrModerator() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || getUserData().role == 'moderator');
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdminOrModerator() || 
        (isAuthenticated() && resource.data.uid == request.auth.uid && 
         request.resource.data.status == resource.data.status); // citizens cannot change status
      allow delete: if isAdmin();
    }

    // Report Status History Collection
    match /report_status_history/{historyId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrModerator();
    }

    // Crisis Alerts Collection
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Upvotes / Confirmation Votes Collection
    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Admin Audit Logs Collection
    match /admin_actions/{actionId} {
      allow read: if isAdminOrModerator();
      allow write: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || resource.data.uid == 'all');
      allow write: if isAuthenticated();
    }
  }
}
